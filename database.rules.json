{
  "rules": {
    "paises": {
      ".read": true,
      ".write": false
    },
    "fichas": {
      ".read": true,
      ".write": true
    },
    "validacion": {
      ".read": true,
      ".write": true
    },
    "usuarios": {
      ".read": "auth != null",
      "$uid": {
        ".write": "$uid === auth.uid"
      }
    }
  }
}
